---
// ============================================================
// src/pages/twin2.astro — Twin 2's Personal Page
// ============================================================
//
// This page shows Twin 2's projects, anime reviews, and game reviews.
//
// SECTIONS:
//   1. Projects       — Portfolio cards (Genome Toolkit + placeholders)
//   2. Anime Reviews  — Cards pulled from twin2-anime-reviews collection
//   3. Game Reviews   — Cards pulled from twin2-game-reviews collection
//
// HOW TO ADD A REVIEW:
//   Create a new .md file in the matching content folder:
//     Anime → src/content/twin2-anime-reviews/my-review.md
//     Games → src/content/twin2-game-reviews/my-review.md
//   The review will appear here automatically at the next build.
//   See existing sample files for the required frontmatter format.
// ============================================================

import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// ── Fetch reviews at build time ──────────────────────────────
// getCollection() reads all .md files from the named folder.
// We filter out drafts and sort by date (newest first).

const animeReviews = (await getCollection('twin2-anime-reviews'))
  .filter(r => !r.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const gameReviews = (await getCollection('twin2-game-reviews'))
  .filter(r => !r.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Twin 2 Projects — Iremi Twins"
  description="Projects and apps by Twin 2 of the Iremi Twins."
>
  <main>
    <!-- ══════════════════════════════════════════════════════
         SECTION 1: Projects
         ══════════════════════════════════════════════════════ -->
    <section class="portfolio section" style="padding-top: 8rem;">
      <div class="container">

        <p class="section__label">// twin 2</p>
        <h2 class="section__title">Twin 2's <span class="highlight">Projects</span></h2>

        <div class="portfolio__grid">

          <!-- ── Genome Toolkit ── -->
          <article class="project-card card" data-animate>
            <div class="project-card__header">
              <span class="project-card__type">Web App</span>
              <div class="project-card__links">
                <a href="/twin2/genome-toolkit" aria-label="Open Genome Toolkit">↗</a>
              </div>
            </div>
            <a href="/twin2/genome-toolkit" style="text-decoration:none;color:inherit;">
              <h3>Genome Toolkit</h3>
              <p>Browser-based genomic data analysis — parse FASTA/FASTQ files, search motifs, visualize GC content, and compare variant datasets. Fully Built with Claude Opus 4.6</p>
            </a>
            <div class="project-card__tech">
              <span>React</span>
              <span>TypeScript</span>
              <span>Chart.js</span>
              <span>Zustand</span>
            </div>
          </article>

          <!-- ── Flappy Bird ── -->
          <article class="project-card card" data-animate>
            <div class="project-card__header">
              <span class="project-card__type">Game</span>
              <div class="project-card__links">
                <a href="/FlappyBird/FlappyBird.html" target="_blank" rel="noopener noreferrer" aria-label="Play Flappy Bird">▶</a>
              </div>
            </div>
            <a href="/FlappyBird/FlappyBird.html" target="_blank" rel="noopener noreferrer" style="text-decoration:none;color:inherit;">
              <h3>Flappy Bird</h3>
              <p>A classic Flappy Bird recreation — tap or press space to keep the bird airborne and dodge the pipes. Built with Godot and exported for the web.</p>
            </a>
            <div class="project-card__tech">
              <span>Godot</span>
              <span>GDScript</span>
              <span>HTML5</span>
            </div>
          </article>

          <!-- ── Placeholder card 3 ── -->
          <article class="project-card card" data-animate>
            <div class="project-card__header">
              <span class="project-card__type">Coming Soon</span>
              <div class="project-card__links"></div>
            </div>
            <h3>Project Name</h3>
            <p>Details about this project coming soon.</p>
            <div class="project-card__tech">
              <span>TBD</span>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 2: Anime Reviews
         ─────────────────────────────────────────────────────
         Cards are auto-generated from .md files in:
           src/content/twin2-anime-reviews/

         Each card links to its full review page at:
           /twin2/twin2-anime-reviews/<slug>
         ══════════════════════════════════════════════════════ -->
    <section class="section" id="anime-reviews">
      <div class="container">
        <p class="section__label">// anime reviews</p>
        <h2 class="section__title">Anime <span class="highlight">Reviews</span></h2>

        {animeReviews.length > 0 ? (
          <div class="review__grid">
            {animeReviews.map(review => {
              const filled = Array.from({ length: review.data.rating }, (_, i) => i);
              const empty  = Array.from({ length: 5 - review.data.rating }, (_, i) => i);
              const displayDate = review.data.date.toLocaleDateString('en-GB', {
                month: 'short', year: 'numeric',
              });
              return (
                <article class="review-card card" data-animate>
                  {/* Cover image or placeholder */}
                  {review.data.coverImage ? (
                    <img src={review.data.coverImage} alt={review.data.title} class="review-card__cover" />
                  ) : (
                    <div class="review-card__cover--placeholder">🎬</div>
                  )}

                  {/* Star rating */}
                  <div class="review-card__stars">
                    {filled.map(() => <span class="review-card__star--filled">★</span>)}
                    {empty.map(() => <span class="review-card__star--empty">★</span>)}
                  </div>

                  {/* Title linked to the full review */}
                  <h3><a href={`/twin2/twin2-anime-reviews/${review.slug}`}>{review.data.title}</a></h3>

                  {/* Short description */}
                  <p class="review-card__desc">{review.data.description}</p>

                  {/* Date */}
                  <span class="review-card__date">{displayDate}</span>
                </article>
              );
            })}
          </div>
        ) : (
          <p style="color: var(--clr-muted);">No anime reviews yet — check back soon!</p>
        )}
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SECTION 3: Video Game Reviews
         ─────────────────────────────────────────────────────
         Cards are auto-generated from .md files in:
           src/content/twin2-game-reviews/

         Each card links to its full review page at:
           /twin2/twin2-game-reviews/<slug>
         ══════════════════════════════════════════════════════ -->
    <section class="section" id="game-reviews">
      <div class="container">
        <p class="section__label">// game reviews</p>
        <h2 class="section__title">Video Game <span class="highlight">Reviews</span></h2>

        {gameReviews.length > 0 ? (
          <div class="review__grid">
            {gameReviews.map(review => {
              const filled = Array.from({ length: review.data.rating }, (_, i) => i);
              const empty  = Array.from({ length: 5 - review.data.rating }, (_, i) => i);
              const displayDate = review.data.date.toLocaleDateString('en-GB', {
                month: 'short', year: 'numeric',
              });
              return (
                <article class="review-card card" data-animate>
                  {/* Cover image or placeholder */}
                  {review.data.coverImage ? (
                    <img src={review.data.coverImage} alt={review.data.title} class="review-card__cover" />
                  ) : (
                    <div class="review-card__cover--placeholder">🎮</div>
                  )}

                  {/* Star rating */}
                  <div class="review-card__stars">
                    {filled.map(() => <span class="review-card__star--filled">★</span>)}
                    {empty.map(() => <span class="review-card__star--empty">★</span>)}
                  </div>

                  {/* Title linked to the full review */}
                  <h3><a href={`/twin2/twin2-game-reviews/${review.slug}`}>{review.data.title}</a></h3>

                  {/* Short description */}
                  <p class="review-card__desc">{review.data.description}</p>

                  {/* Date */}
                  <span class="review-card__date">{displayDate}</span>
                </article>
              );
            })}
          </div>
        ) : (
          <p style="color: var(--clr-muted);">No game reviews yet — check back soon!</p>
        )}
      </div>
    </section>

  </main>
</BaseLayout>
